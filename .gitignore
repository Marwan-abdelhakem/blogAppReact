# =============================================================================
#  PostApp — Root .gitignore
#  Covers: Frontend (React/Vite) · Backend (Node.js/Express) · Tooling · OS
# =============================================================================


# =============================================================================
#  DEPENDENCIES
# =============================================================================

node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# =============================================================================
#  ENVIRONMENT VARIABLES  ← never commit secrets
# =============================================================================

.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# Backend config files that may contain secrets
config.json
secrets.json


# =============================================================================
#  FRONTEND — React / Vite build artifacts
# =============================================================================

# Vite / CRA production builds
frontend/dist/
frontend/build/

# Next.js (if ever migrated)
frontend/.next/
frontend/out/

# Vite cache
frontend/.vite/

# TypeScript incremental build info
frontend/*.tsbuildinfo


# =============================================================================
#  BACKEND — Node.js / Express artifacts
# =============================================================================

# Compiled output (if using TypeScript or a build step)
backend/dist/
backend/build/

# Database files
*.sqlite
*.sqlite3
*.db

# Upload / temp directories
backend/uploads/
backend/tmp/


# =============================================================================
#  LOGS
# =============================================================================

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock


# =============================================================================
#  TESTING & COVERAGE
# =============================================================================

coverage/
*.lcov
.nyc_output/

# Vitest / Jest cache
.vitest-cache/
.jest-cache/


# =============================================================================
#  IDE & EDITOR SETTINGS
# =============================================================================

# VS Code — keep shared settings if desired, ignore personal/local overrides
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs swap files
*.swp
*.swo
*~


# =============================================================================
#  OS-GENERATED FILES
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory


# =============================================================================
#  PACKAGE MANAGER CACHES
# =============================================================================

.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml


# =============================================================================
#  MISC
# =============================================================================

# Vercel deployment cache
.vercel/

# Turbo / monorepo build cache
.turbo/

# Diagnostic reports (Node.js)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
